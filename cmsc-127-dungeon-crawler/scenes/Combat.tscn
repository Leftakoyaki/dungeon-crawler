[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/Combat.gd" id="1_combat"]

[node name="Combat" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_combat")

; ── Full-screen background ────────────────────────────────────────────────────
[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.08, 0.12, 1.0)

; ── Battle area — top 55% of screen ──────────────────────────────────────────
; Replace PlayerSprite and EnemySprite ColorRects with Sprite2D when art is ready.
[node name="BattleArea" type="HBoxContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 0.55
offset_left = 20.0
offset_right = -20.0
theme_override_constants/separation = 0

; ── Player side (left) ────────────────────────────────────────────────────────
[node name="PlayerSide" type="VBoxContainer" parent="BattleArea"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="PlayerSprite" type="ColorRect" parent="BattleArea/PlayerSide"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(130, 180)
color = Color(0.18, 0.32, 0.72, 0.85)

[node name="PlayerNameLabel" type="Label" parent="BattleArea/PlayerSide"]
layout_mode = 2
text = "PLAYER"

[node name="PlayerHPBar" type="ProgressBar" parent="BattleArea/PlayerSide"]
layout_mode = 2
custom_minimum_size = Vector2(0, 18)
max_value = 100
value = 100
show_percentage = false

[node name="PlayerHPLabel" type="Label" parent="BattleArea/PlayerSide"]
layout_mode = 2
text = "HP  -- / --"

[node name="PlayerSPBar" type="ProgressBar" parent="BattleArea/PlayerSide"]
layout_mode = 2
custom_minimum_size = Vector2(0, 18)
max_value = 4
value = 4
show_percentage = false

[node name="PlayerSPLabel" type="Label" parent="BattleArea/PlayerSide"]
layout_mode = 2
text = "SP  -- / --"

[node name="UltLabel" type="Label" parent="BattleArea/PlayerSide"]
layout_mode = 2
text = "ULT  0 / 2"

; ── Centre spacer ─────────────────────────────────────────────────────────────
[node name="BattleSpacer" type="Control" parent="BattleArea"]
layout_mode = 2
size_flags_horizontal = 3

; ── Enemy side (right) ────────────────────────────────────────────────────────
[node name="EnemySide" type="VBoxContainer" parent="BattleArea"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="EnemySprite" type="ColorRect" parent="BattleArea/EnemySide"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(130, 180)
color = Color(0.72, 0.18, 0.18, 0.85)

[node name="EnemyNameLabel" type="Label" parent="BattleArea/EnemySide"]
layout_mode = 2
text = "ENEMY"

[node name="EnemyHPBar" type="ProgressBar" parent="BattleArea/EnemySide"]
layout_mode = 2
custom_minimum_size = Vector2(0, 18)
max_value = 100
value = 100
show_percentage = false

[node name="EnemyHPLabel" type="Label" parent="BattleArea/EnemySide"]
layout_mode = 2
text = "HP  -- / --"

; ── Combat log — 55%–70% ──────────────────────────────────────────────────────
[node name="LogPanel" type="PanelContainer" parent="."]
anchor_top = 0.55
anchor_right = 1.0
anchor_bottom = 0.70
offset_left = 20.0
offset_right = -20.0

[node name="LogLabel" type="Label" parent="LogPanel"]
layout_mode = 2
autowrap_mode = 3
text = ""

; ── Skill buttons — 70%–87% ───────────────────────────────────────────────────
; Buttons are added here dynamically by Combat.gd._build_skill_buttons()
; When sprites are ready, wrap each skill in a Panel styled like a card.
[node name="SkillContainer" type="HBoxContainer" parent="."]
anchor_top = 0.70
anchor_right = 1.0
anchor_bottom = 0.87
offset_left = 20.0
offset_right = -20.0
theme_override_constants/separation = 10

; ── Action row — 87%–100% ─────────────────────────────────────────────────────
[node name="ActionRow" type="HBoxContainer" parent="."]
anchor_top = 0.87
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_right = -20.0
offset_bottom = -10.0
theme_override_constants/separation = 16

[node name="UsePotionButton" type="Button" parent="ActionRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Use Potion"

[node name="FleeButton" type="Button" parent="ActionRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Flee"
